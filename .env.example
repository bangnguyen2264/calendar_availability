# ==============================================================================
# Calendar Availability API – Biến môi trường
# ==============================================================================
# Copy file này thành .env rồi điền giá trị thật:
#   cp .env.example .env
#
# - Local dev  : dùng giá trị mặc định (không cần set gì, docker-compose up là chạy)
# - Render     : dùng Blueprint (render.yaml) → Render TỰ ĐỘNG inject, không cần .env
# ==============================================================================

# --- Server ---
PORT=8080

# ==============================================================================
# DATABASE – Có 2 cách kết nối (chọn 1):
# ==============================================================================
#
# ▸ CÁCH 1: Full URL (ưu tiên nếu set)
# DATABASE_URL=jdbc:postgresql://localhost:5432/db
#
# ▸ CÁCH 2: Biến rời (dùng khi KHÔNG set DATABASE_URL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=db
DATABASE_USERNAME=admin
DATABASE_PASSWORD=password

# --- JPA ---
JPA_DDL_AUTO=create-drop
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# --- App metadata (Swagger) ---
# APP_BASE_URL=http://localhost:8080    # Local: tự fallback, không cần set
APP_TITLE=MasterBranch - backend  Interview Questions 2026
APP_VERSION=1.0.0
APP_DESCRIPTION=API quản lý lịch và kiểm tra khung giờ trống
APP_CONTACT_NAME=MasterBranch Team
APP_CONTACT_EMAIL=ngtbang2264.dev@gmail.com
SWAGGER_ENABLE=true

# --- Logging ---
LOG_LEVEL_SQL=DEBUG
LOG_LEVEL_BINDER=TRACE
